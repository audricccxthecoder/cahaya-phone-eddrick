# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cahaya_phone_crm

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# CORS & FRONTEND URLs
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500

# ============================================
# WHATSAPP BRIDGE (Baileys self-hosted — gratis)
# wa-bridge di-deploy sebagai service terpisah di Railway.
# URL ini adalah internal URL dari Railway (pakai .railway.internal)
# atau URL public HTTPS kalau sudah di-expose.
# ============================================
WA_BRIDGE_URL=http://localhost:3001
WA_BRIDGE_SECRET=ganti-dengan-secret-random-yang-kuat

# ============================================
# SYNC SECRET (untuk quick-sync contacts, kirim via header X-Sync-Key)
# ============================================
SYNC_SECRET=your_random_sync_secret_here

# ============================================
# MAIL CONFIGURATION (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@cahaya-phone.com

# ============================================
# JWT & SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ============================================
# STATUS EXPIRY
# ============================================
STATUS_EXPIRE_HOURS=24
STATUS_OLD_LABEL=Old

# ============================================
# GOOGLE CONTACTS API
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google/callback