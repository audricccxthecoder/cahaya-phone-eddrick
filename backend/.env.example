# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cahaya_phone_crm

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# CORS & FRONTEND URLs
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500

# ============================================
# WHATSAPP CLOUD API (Meta Official)
# Dapatkan dari: https://developers.facebook.com → WhatsApp
# ============================================
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_BUSINESS_ACCOUNT_ID=your_business_account_id
WA_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token

# Template names (harus sudah di-approve di Meta Business Manager)
WA_TEMPLATE_AUTO_REPLY=terima_kasih_belanja
WA_TEMPLATE_BIRTHDAY=ucapan_ulang_tahun
WA_TEMPLATE_BROADCAST=promo_info

# ============================================
# SYNC SECRET (untuk quick-sync contacts, kirim via header X-Sync-Key)
# ============================================
SYNC_SECRET=your_random_sync_secret_here

# ============================================
# MAIL CONFIGURATION (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@cahaya-phone.com

# ============================================
# JWT & SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ============================================
# STATUS EXPIRY
# ============================================
STATUS_EXPIRE_HOURS=24
STATUS_OLD_LABEL=Old

# ============================================
# GOOGLE CONTACTS API
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google/callback